# ============================================================
# MuseWrite — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Only Tier 1 variables are required to get started.
# ============================================================


# ────────────────────────────────────────────────────────────
# Tier 1: Required (get started in 2 minutes)
# ────────────────────────────────────────────────────────────

# LLM Provider — any OpenAI-compatible API endpoint.
# Examples:
#   OpenAI:       https://api.openai.com/v1
#   DeepSeek:     https://api.deepseek.com/v1
#   Local Ollama: http://localhost:11434/v1
#   LLM Proxy:    http://llm-proxy:8081/v1  (for /v1/responses-only APIs)
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o-mini


# ────────────────────────────────────────────────────────────
# Tier 2: Recommended
# ────────────────────────────────────────────────────────────

# Embedding — defaults to same provider as LLM if not set.
# EMBEDDING_BASE_URL=
# EMBEDDING_API_KEY=
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM=1536

# Database credentials
POSTGRES_PASSWORD=postgres
NEO4J_PASSWORD=neo4jpassword

# Frontend auth
VITE_API_TOKEN=local-dev-token
AUTH_TOKENS=local-user:local-dev-token


# ────────────────────────────────────────────────────────────
# Tier 3: Advanced (most users never need to touch these)
# ────────────────────────────────────────────────────────────

# CONFIG_PROFILE=local-dev          # local-dev | quality-first

# LightRAG (enable with: docker compose --profile rag up)
# LIGHTRAG_ENABLED=false

# Graphiti temporal knowledge graph
# GRAPHITI_ENABLED=false

# Observability
# LANGFUSE_ENABLED=false
# LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
