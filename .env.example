WEB_PORT=8080
API_PORT=8000
VITE_API_BASE=
# Or run: python scripts/init_local_env.py (will generate a random token into .env)
VITE_API_TOKEN=local-dev-token

# ==============================
# Configuration profile
# local-dev | quality-first
# ==============================
CONFIG_PROFILE=local-dev

# ==============================
# Core required settings
# ==============================
AUTH_ENABLED=true
AUTH_TOKENS=local-user:local-dev-token
AUTH_TOKEN=
AUTH_USER=local-user
# Optional: 1:local-user,2:local-user|coauthor
AUTH_PROJECT_OWNERS=
AUTH_DISABLED_USER=local-user

POSTGRES_DB=novel_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

LLM_PROVIDER=stub
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
# strict: prefer json_schema/tool calling and fail fast if provider cannot comply
# compat: allow openai-compatible fallback to response_format={type:"json_object"}
LLM_STRUCTURED_MODE=strict

LIGHTRAG_ENABLED=false
LIGHTRAG_BASE_URL=http://lightrag:9621

NEO4J_ENABLED=true
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4jpassword
NEO4J_DATABASE=neo4j
NEO4J_GDS_GRAPH_NAME_PREFIX=novel_ppr
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# ==============================
# Negotiable strategy toggles
# ==============================
RAG_ROUTE_POLICY=mix
QUALITY_GATE_ENFORCE=false
CITATION_POLICY=off
CITATION_MIN_COUNT=1
CONTEXT_WINDOW_PROFILE=balanced
CONTEXT_COMPRESSION_MODE=rerank
GHOST_ENTITY_GROUNDING_ENABLED=true
GHOST_ENTITY_LLM_TIMEOUT_SECONDS=3.0

# ==============================
# Observability (optional)
# ==============================
LANGFUSE_ENABLED=false
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ==============================
# CI / regression gate overrides (optional)
# Keep these only for eval workflows.
# ==============================
RAGAS_GATE_ENABLED=false
RAGAS_THRESHOLD=0.55

# ==============================
# LightRAG container tuning (optional)
# ==============================
LIGHTRAG_PORT=9621
LIGHTRAG_IMAGE=ghcr.io/hkuds/lightrag:latest
LIGHTRAG_OPENAI_API_KEY=
LIGHTRAG_WORKING_DIR=/app/data/rag_storage
LIGHTRAG_INPUT_DIR=/app/data/inputs
LIGHTRAG_TIMEOUT=300
LIGHTRAG_LLM_TIMEOUT=180
LIGHTRAG_EMBEDDING_TIMEOUT=180
LIGHTRAG_LLM_BINDING=openai
LIGHTRAG_LLM_MODEL=Qwen/Qwen3-8B
LIGHTRAG_LLM_BASE_URL=https://api.siliconflow.cn/v1
LIGHTRAG_LLM_API_KEY=
LIGHTRAG_EMBEDDING_BINDING=openai
LIGHTRAG_EMBEDDING_MODEL=BAAI/bge-m3
LIGHTRAG_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
LIGHTRAG_EMBEDDING_API_KEY=
LIGHTRAG_EMBEDDING_DIM=1024
LIGHTRAG_RERANK_ENABLED=true
LIGHTRAG_RERANK_BINDING=null
LIGHTRAG_RERANK_MODEL=BAAI/bge-reranker-v2-m3
LIGHTRAG_RERANK_BASE_URL=https://api.siliconflow.cn/v1/rerank
LIGHTRAG_RERANK_API_KEY=
